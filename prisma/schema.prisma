datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

// 1. Definisikan ENUM yang dibutuhkan
enum UserRole {
  FIELD_TECH
  CUST_ADMIN
  ENGINEER
  LOGISTIC_PARTNER
  SYS_ADMIN
  DOP_STAFF
}

enum RmaStatus {
  PENDING_APPROVAL
  APPROVED
  SHIPPED
  GOOD_PART_RECEIVED
  FAULTY_PART_RETURNED
  CLOSED
}

// 2. Tabel Users
model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(100)
  password_hash String    @default("") @db.VarChar(255) 
  role          UserRole
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamp()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp() 

  location_logs  location_log[]
  rma_as_tech    rma_request[]    @relation("TechRma")
  rma_as_courier rma_request[]    @relation("CourierRma")

  @@map("users")
}

// 3. Tabel Parts (Katalog)
model part {
  part_number String  @id @db.VarChar(50)
  name        String  @db.VarChar(150)
  description String? @db.Text

  // Relasi
  rma_requests    rma_request[]
  dopInventories  dop_inventory[]
  replenishOrders replenish_order[]
}

// 4. Tabel DOP Sites
model dop_site {
  id      String  @id @default(uuid()) @db.Uuid
  name    String  @db.VarChar(100)
  address String? @db.Text

  // Menggunakan Unsupported untuk tipe data spasial PostGIS
  location Unsupported("geography(Point, 4326)")

  // Relasi
  rma_requests    rma_request[]
  dopInventories  dop_inventory[]
  replenishOrders replenish_order[]

  @@map("dop_sites")
}

// 5. Tabel Utama: RMA Requests
model rma_request {
  id                   String    @id @default(uuid()) @db.Uuid
  rma_number           String    @unique @db.VarChar(20)
  field_tech_id        String    @db.Uuid
  courier_id           String?   @db.Uuid // Diisi saat unit mulai dikirim oleh PSS Logistik
  part_number          String    @db.VarChar(50)
  faulty_serial_number String    @unique @db.VarChar(100)
  good_serial_number   String?   @db.VarChar(100)
  dop_id               String    @db.Uuid
  status               RmaStatus @default(PENDING_APPROVAL)
  customer_ticket_id   String?   @db.VarChar(100)
  rating               Int       @default(0) // Skala 1-5, default 0 artinya belum mengisi
  feedback_notes       String?   @db.Text
  created_at           DateTime  @default(now()) @db.Timestamp()
  approved_at          DateTime? @db.Timestamp()
  closed_at            DateTime? @db.Timestamp()

  // Definisi Relasi ke tabel lain
  courier    User?    @relation("CourierRma", fields: [courier_id], references: [id])
  field_tech User     @relation("TechRma", fields: [field_tech_id], references: [id])
  part       part     @relation(fields: [part_number], references: [part_number])
  dop        dop_site @relation(fields: [dop_id], references: [id])

  // Relasi ke logs koordinat kurir
  location_logs location_log[]

  @@map("rma_requests")
}

// 6. Tabel Geolokasi (Location Logs untuk Melacak PSS Logistik)
model location_log {
  id            BigInt   @id @default(autoincrement()) @db.BigInt
  rma_id        String   @db.Uuid
  user_id       String   @db.Uuid // User ID di sini adalah milik Kurir (LOGISTIC_PARTNER)
  battery_level Int?
  pinged_at     DateTime @default(now()) @db.Timestamp()

  // Koordinat Spasial PostGIS
  coordinate Unsupported("geography(Point, 4326)")

  // Definisi Relasi
  rma  rma_request @relation(fields: [rma_id], references: [id], onDelete: Cascade)
  user User        @relation(fields: [user_id], references: [id])

  @@map("location_logs")
}

// 7. Tabel Manajemen Stok Gudang DOP
model dop_inventory {
  id             String @id @default(uuid()) @db.Uuid
  dop_id         String @db.Uuid
  part_number    String @db.VarChar(50)
  stock_good_qty Int    @default(5)
  min_threshold  Int    @default(2)

  // Relasi
  dop  dop_site @relation(fields: [dop_id], references: [id], onDelete: Cascade)
  part part     @relation(fields: [part_number], references: [part_number], onDelete: Cascade)

  @@unique([dop_id, part_number])
  @@map("dop_inventories")
}

// 8. Tabel Dokumen Pengisian Ulang Stok untuk Tim Logistik (L3 to L4 Replenish)
model replenish_order {
  id               String   @id @default(uuid()) @db.Uuid
  dop_id           String   @db.Uuid
  part_number      String   @db.VarChar(50)
  quantity_to_ship Int
  status           String   @default("DRAFT")
  created_at       DateTime @default(now()) @db.Timestamp()

  // Relasi
  dop  dop_site @relation(fields: [dop_id], references: [id], onDelete: Cascade)
  part part     @relation(fields: [part_number], references: [part_number], onDelete: Cascade)

  @@map("replenish_orders")
}